{
    "name": "sql-opfs-testing",
    "private": true,
    "version": "0.0.0",
    "type": "module",
    "scripts": {
        "start": "run-p -s -l start:*",
        "start:vite": "vite",
        "start:typecheck": "npm run typecheck:watch",
        "build": "vite build",
        "lint": "npx @biomejs/biome check ./src",
        "lint:fix": "npx @biomejs/biome check ./src --write",
        "lint:fix:unsafe": "npx @biomejs/biome check ./src --write --unsafe",
        "test": "vitest run",
        "test:watch": "vitest ",
        "typecheck": "node ./typecheck.js",
        "typecheck:watch": "node ./typecheck_watch.js",
        "generate_test": "git commit --allow-empty -m \"GENERATE_TEST\" && git push"
    },
    "optionalDependencies": {
        "@rollup/rollup-linux-x64-gnu": "4.59.0"
    },
    "devDependencies": {
        "@biomejs/biome": "2.4.4",
        "@sqlite.org/sqlite-wasm": "3.51.2-build6",
        "@tailwindcss/container-queries": "0.1.1",
        "@tailwindcss/postcss": "4.2.1",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "@types/wicg-file-system-access": "2023.10.7",
        "@vitejs/plugin-react": "5.1.4",
        "esbuild": "0.27.3",
        "esbuild-helpers": "2.0.5",
        "npm-run-all": "4.1.5",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "react-router-dom": "7.13.1",
        "tailwindcss": "4.2.1",
        "typescript": "5.9.3",
        "vite": "7.3.1",
        "vitest": "4.0.18",
        "zustand": "5.0.11",
        "tailwind-merge": "^3.5.0"
    },
    "dependencies": {
        "@simple-html/grid": "^5.0.0-next.97"
    }
}